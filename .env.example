VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
TMDB_API_KEY=your-tmdb-v3-api-key

# Module 7 (real accounts) — server-only, deliberately no VITE_ prefix so
# this can never end up in the browser bundle even by mistake. Bypasses RLS
# entirely: used by api/admin-invite.js, api/admin-revoke.js, and
# api/keep-alive.js, never by anything the client calls directly.
# Get it from Supabase: Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key
